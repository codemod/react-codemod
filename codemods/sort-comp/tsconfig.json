{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "ESNext"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "@codemod.com/jssg-types",
      "node"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "erasableSyntaxOnly": true,
    "strict": true,
    "strictNullChecks": true
  },
  "exclude": [
    "tests"
  ]
}
