{
  "name": "react-codemod",
  "version": "0.1.0",
  "private": true,
  "description": "A collection of codemods to help update React apps",
  "type": "module",
  "scripts": {
    "test": "pnpm -r --filter \"@react-new/*\" test",
    "check-types": "pnpm -r --filter \"@react-new/*\" check-types",
    "changeset": "changeset",
    "version-packages": "changeset version && bash scripts/sync-codemod-versions.sh",
    "ci": "pnpm run test && pnpm run check-types"
  },
  "keywords": [
    "codemod",
    "react",
    "jssg",
    "ast-grep"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codemod/jssg-react-codemods.git"
  },
  "packageManager": "pnpm@9.14.2",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "latest"
  },
  "dependencies": {
    "@jssg/utils": "^0.0.2"
  }
}
